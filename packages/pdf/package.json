{
  "name": "@storywink/pdf",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --outDir dist --declaration --declarationMap --sourceMap",
    "dev": "tsc --outDir dist --declaration --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@sparticuz/chromium": "^131.0.1",
    "@storywink/database": "*",
    "@storywink/shared": "*",
    "puppeteer-core": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
