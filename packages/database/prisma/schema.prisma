// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookStatus {
  DRAFT
  GENERATING
  STORY_READY
  ILLUSTRATING
  COMPLETED
  FAILED
  PARTIAL
}

enum BookType {
  PHOTO_STORY
  AVATAR_STORY
}

enum AvatarKind {
  CHILD
  ADULT
  PET
  TOY
}

enum AvatarStatus {
  DRAFT
  READY
}

enum RenditionStatus {
  PENDING
  READY
  FAILED
}

enum PageType {
  SINGLE
  SPREAD
}

enum PageSource {
  PHOTO
  BRIDGE
}

model User {
  id            String         @id @default(cuid())
  clerkId       String         @unique
  email         String         @unique
  name          String?
  imageUrl      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  books         Book[]
  assets        Asset[]
  profile       UserProfile?
  notifications Notification[]
  cartItems     CartItem[]
  printOrders   PrintOrder[]
  avatars       Avatar[]
}

model Book {
  id                String         @id @default(cuid())
  userId            String
  title             String
  status            BookStatus     @default(DRAFT)
  bookType   BookType   @default(PHOTO_STORY)
  pageLength        Int // 8, 12, or 16
  language          String     @default("en") // "en" or "ja"
  artStyle          String?
  tone              String?
  typography        String?
  theme             String?
  keyCharacters        String?
  childName            String?
  additionalCharacters String?   // JSON: [{"name":"Sarah","relationship":"Mom"}]
  specialObjects       String?
  excitementElement String?
  coverAssetId      String?
  coverImageUrl     String?   // AI-generated cover illustration (separate from page's story illustration)
  characterIdentity Json?     // Canonical character description for illustration consistency
  qcRound           Int            @default(0) // Current QC iteration (0 = first pass, 1+ = re-illustration)
  autoIllustrate    Boolean        @default(false) // Chain straight into illustration after story success (DB default false keeps pre-existing books on the manual flow; create route sets true for new books)
  eventSummary      String?   // One-line "what actually happened" brief — AI-drafted from photos, parent-editable, feeds the story prompt (supersedes theme when present)
  learningWords      Json?
  captureQuestions  Json?     // Photo-derived micro-questions + parent's tapped answers: [{id, question, options[], answer|null}]
  generationPhase   String?   // Fine-grained pipeline phase for progress UI (finer than BookStatus)
  firstViewedAt     DateTime? // First time the owner opened a readable preview — gates the one-time reveal
  characterReferences Json?   // Character sheet refs keyed by (characterId, artStyle), retained across style flips
  promptTokens      Int?
  completionTokens  Int?
  totalTokens       Int?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages             Page[]
  notifications     Notification[]
  cartItems         CartItem[]
  printOrders       PrintOrder[]
  illustrationQcResults IllustrationQcResult[]
  bookAvatars BookAvatar[]

  @@index([userId])
  @@index([status])
}

model Page {
  id         String @id @default(cuid())
  bookId     String
  pageNumber Int
  index      Int    @default(0)

  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id])

  originalImageUrl  String?
  generatedImageUrl String?
  text              String?
  textConfirmed     Boolean? @default(false)
  illustrationNotes String?
  illustrationMood  String?  // STORY QUALITY V2 (photo path): the story model's per-page mood cue ("hushed wonder") — rendered into the interior prompt only when STORY_ILLUS_MOOD_ENABLED
  learningWordsUsed String[]  @default([])
  analysis          Json?    // Photo perception: {assetId, setting, action, emotion, eventSignals[], narrativeRole} — assetId marks freshness (stale when the photo was swapped)

  isTitlePage Boolean @default(false)

  source             PageSource @default(PHOTO) // BRIDGE pages are app-authored (assetId stays null)
  bridgeScene        Json?      // Structured scene for BRIDGE pages: {location, timeOfDay, action, charactersPresent, outfitFrom, props}
  lastRenderProvider String?    // Stamped at render time — finalize cannot infer which provider drew the page
  lastRenderModel    String?    // Exact model id used for the last successful render
  lastRenderHadSheet Boolean?   // Stamped at render time — whether the render actually received character-sheet refs (null = predates the stamp)

  pageType         PageType
  moderationStatus String   @default("PENDING")
  moderationReason String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  book             Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([assetId])
}

model Asset {
  id           String   @id @default(cuid())
  userId       String
  url          String
  thumbnailUrl String?
  publicId     String   @unique
  fileType     String
  size         Int
  width        Int?
  height       Int?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages        Page[] // Add relation back to Page model
  avatarPhotos AvatarPhoto[]

  @@index([userId])
}


/**
 * Account-level character: the child, a grown-up, a pet, or a beloved toy,
 * promoted from a finished book or created in the studio. `identity` reuses
 * the CharacterDescription JSON shape so the illustration pipeline consumes
 * it unchanged. Named Avatar (not Character) deliberately — a book-scoped
 * Character table existed briefly in Dec 2025 and was reverted.
 */
model Avatar {
  id          String       @id @default(cuid())
  userId      String
  displayName String
  kind        AvatarKind
  status      AvatarStatus @default(DRAFT)
  identity    Json?
  /** Book the avatar was promoted from, if any (no FK — books are deletable). */
  promotedFromBookId String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  renditions  AvatarRendition[]
  photos      AvatarPhoto[]
  bookLinks   BookAvatar[]

  @@index([userId])
}

/** One styled master reference per (avatar, artStyle): 2x2 turnaround sheet + display portrait. */
model AvatarRendition {
  id                 String          @id @default(cuid())
  avatarId           String
  artStyle           String
  status             RenditionStatus @default(PENDING)
  turnaroundSheetUrl String?
  portraitUrl        String?
  /** Full-body waving cutout (transparent PNG; white-background fallback). Garnish — null when generation failed. */
  cutoutUrl          String?
  provider           String?
  model              String?
  validatedAt        DateTime?
  error              String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  avatar             Avatar          @relation(fields: [avatarId], references: [id], onDelete: Cascade)

  @@unique([avatarId, artStyle])
  @@index([avatarId])
}

/**
 * Transient staging join: photos uploaded (or picked) to make this avatar.
 * Deleted on approval per the delete-after-approval retention posture —
 * photos that also back book pages are exempt via the shared-asset guard.
 */
model AvatarPhoto {
  avatarId  String
  assetId   String
  createdAt DateTime @default(now())
  avatar    Avatar   @relation(fields: [avatarId], references: [id], onDelete: Cascade)
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([avatarId, assetId])
  @@index([assetId])
}

/** Which account avatars star in a book (cast link for AVATAR_STORY + X6c reuse). */
model BookAvatar {
  bookId      String
  avatarId    String
  /** Perception roster characterId this avatar plays in THIS book, when linked. */
  characterId String?
  createdAt   DateTime @default(now())
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  avatar      Avatar   @relation(fields: [avatarId], references: [id], onDelete: Cascade)

  @@id([bookId, avatarId])
  @@index([avatarId])
}

model UserProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  firstName         String?
  lastName          String?
  bio               String?
  dateOfBirth       DateTime?
  location          String?
  preferredLanguage String    @default("en")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Notification model for in-app notifications (e.g., book completion)
model Notification {
  id        String   @id @default(cuid())
  userId    String
  bookId    String?
  type      String // 'BOOK_COMPLETED', 'BOOK_FAILED', 'BOOK_PARTIAL'
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book? @relation(fields: [bookId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([createdAt])
}

// Per-image QC scores persisted from book-finalize (and later cover/sheet QC).
// target keeps cover/sheet rows out of page-drift stats.
model IllustrationQcResult {
  id           String   @id @default(cuid())
  bookId       String
  pageId       String?
  target       String   @default("page") // 'page' | 'cover' | 'sheet'
  qcRound      Int
  charScore    Float?
  styleScore   Float?
  overallScore Float?
  passed       Boolean
  provider     String?
  model        String?
  hadSheet     Boolean  @default(false)
  feedback     String?
  createdAt    DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([createdAt])
}

// Product funnel telemetry (create started, story ready, first open, ...).
// Deliberately unrelated (no FKs) so event writes never fail on deleted rows.
model AppEvent {
  id        String   @id @default(cuid())
  userId    String?
  bookId    String?
  name      String
  props     Json?
  createdAt DateTime @default(now())

  @@index([name, createdAt])
  @@index([bookId])
}

// Worker diagnostic logging table
// Captures failure details that survive process crashes
model WorkerDiagnostic {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Job identification
  jobId       String
  jobType     String // 'story', 'illustration', 'finalize'
  attemptNum  Int // Current attempt number (1-5)
  maxAttempts Int // Total attempts allowed

  // Book/Page context
  bookId     String?
  pageId     String?
  pageNumber Int?

  // Error details
  errorType    String // 'missing_reference_url', 'gemini_error', 'fetch_error', etc.
  errorMessage String @db.Text
  errorStage   String // Where in the process it failed

  // STYLE_LIBRARY diagnostics (for missing referenceImageUrl errors)
  styleKey                  String?
  styleExists               Boolean?
  hasReferenceImageUrl      Boolean?
  referenceImageUrlType     String?
  referenceImageUrlValue    String?
  availableStyleKeys        String? // JSON array of keys

  // Container/environment info
  instanceId     String
  processId      Int
  hostname       String?
  railwayCommit  String?
  nodeVersion    String?

  @@index([jobId])
  @@index([bookId])
  @@index([pageId])
  @@index([errorType])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// PRINT-ON-DEMAND: Cart & Order Models
// ═══════════════════════════════════════════════════════════════

// Shopping cart for print orders (database-persisted)
model CartItem {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  quantity  Int      @default(1) // 1-10 copies

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId]) // One cart entry per book per user
  @@index([userId])
}

// Print order status enum
enum PrintOrderStatus {
  PENDING_PAYMENT   // Awaiting payment
  PAYMENT_COMPLETED // Payment successful, ready to submit to Lulu
  SUBMITTED_TO_LULU // Sent to Lulu API
  IN_PRODUCTION     // Lulu confirmed, being printed
  SHIPPED           // Order shipped with tracking
  DELIVERED         // Order delivered
  CANCELLED         // Order cancelled
  FAILED            // Order failed
}

// Print order for Lulu POD integration
model PrintOrder {
  id     String           @id @default(cuid())
  userId String
  bookId String
  status PrintOrderStatus @default(PENDING_PAYMENT)

  // Order details
  quantity Int @default(1) // 1-10 copies

  // Lulu-specific fields
  luluPrintJobId String? // Lulu's print job ID
  // Set atomically right before createPrintJob is dispatched. Non-null with a
  // null luluPrintJobId means a run died inside the submission window — the
  // worker fails closed (never resubmits) until a human reconciles with Lulu.
  luluSubmissionAttemptedAt DateTime?
  podPackageId   String? // e.g., "0850X0850FCSTDSS060UW444GXX"
  pageCount      Int? // Interior page count

  // PDF URLs (Dropbox-hosted, publicly accessible for Lulu)
  interiorPdfUrl String?
  coverPdfUrl    String?

  // Pricing (stored in cents to avoid floating point issues)
  printCost    Int? // Cost from Lulu for printing
  shippingCost Int? // Shipping cost from Lulu
  taxAmount    Int? // Tax amount
  totalAmount  Int? // Total charged to customer
  currency     String @default("USD")

  // Stripe payment fields
  stripeSessionId String? // Stripe Checkout session ID
  stripePaymentId String? // Stripe Payment Intent ID

  // Shipping address
  shippingName     String?
  shippingStreet1  String?
  shippingStreet2  String?
  shippingCity     String?
  shippingState    String?
  shippingPostcode String?
  shippingCountry  String  @default("SG")
  shippingPhone    String?
  contactEmail     String?
  shippingTier     String? // e.g., 'sg_my', 'sg_my_express' - maps to Lulu shipping level

  // Tracking information
  trackingNumber    String?
  trackingUrl       String?
  estimatedDelivery DateTime?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  paidAt      DateTime? // When payment was received
  submittedAt DateTime? // When submitted to Lulu
  shippedAt   DateTime? // When Lulu shipped
  deliveredAt DateTime? // When delivered

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([bookId])
  @@index([status])
  @@index([luluPrintJobId])
  @@index([stripeSessionId])
}

