# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/library
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/library

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Dropbox (for Lulu print PDFs) - uses refresh token for automatic renewal
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry error monitoring (optional).
# Leave unset to disable Sentry entirely — the SDK is a silent no-op without a DSN.
# SENTRY_DSN is read server-side; NEXT_PUBLIC_SENTRY_DSN is inlined into the browser bundle.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0

# Rate limiting.
# The limiter uses REDIS_URL (shared with the BullMQ queue) and fails open if Redis is down.
# When RATE_LIMIT_ENFORCE=true, over-limit requests get a 429. Otherwise (default) they are
# logged only and allowed through — useful for observing traffic before turning enforcement on.
# The avatar detect/batch money routes enforce their limits unconditionally.
REDIS_URL=redis://localhost:6379
# RATE_LIMIT_ENFORCE=false

# OpenAI — the batch character studio's subject detection (/api/avatars/detect)
# runs a vision call from the WEB service, not just the workers. Without this
# key the detect route 500s and batch creation is dead at step 1.
OPENAI_API_KEY=sk-...
# ANALYSIS_MODEL=gpt-5-mini   # perception tier override (defaults to gpt-5-mini)

# Feature flags (server + client pairs). The NEXT_PUBLIC_* values are BAKED at
# build time — on Railway they must also be declared as Dockerfile ARGs and in
# turbo.json's build env allowlist (both already done) or the build silently
# drops them and the feature stays dark.
# AVATARS_ENABLED=false
# NEXT_PUBLIC_AVATARS_ENABLED=false
# COLLAGE_PAGES_ENABLED=false
# NEXT_PUBLIC_COLLAGE_PAGES_ENABLED=false
# CHARACTER_SHEETS_ENABLED=false
# BRIDGE_PAGES_ENABLED=false